generator client {
  provider = "prisma-client-js"
}

datasource db {
   provider = "mysql"
   url      = env("DATABASE_URL")
}

// 新增系统配置表
model SiteConfig {
    id         Int      @id @default(autoincrement())
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    key        String   
    value      String   @db.Text
    description String?  @db.Text
    locale     String   @default("zh")

    @@unique([key, locale])
}

// 邀请码模型
model InvitationCode {
    id              Int       @id @default(autoincrement())
    code            String    @unique
    usedCount       Int       @default(0)
    maxUses         Int       @default(1)
    isActive        Boolean   @default(true)
    createdAt       DateTime  @default(now())
    expiresAt       DateTime?
    createdBy       Int
    users           User[]
}

model User {
    id             Int              @id @default(autoincrement())
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    username       String           @unique
    password       String 
    avatar         String?
    isAdmin        Boolean          @default(false)
    storageUsed    BigInt           @default(0) // 用户已使用的存储空间(字节)
    files          UserFile[]
    invitationCode InvitationCode?  @relation(fields: [invitationCodeId], references: [id])
    invitationCodeId Int?
}

// 文件类型枚举
enum FileType {
    // ai生成的图片
    AI_GENERATED_IMAGE
    // 用户上传的文件
    USER_UPLOADED_FILE
    // 图片参数
    PARAMETER_IMAGE
}

model UserFile {
    id          Int      @id @default(autoincrement())
    name        String
    size        Int
    type        String
    path        String
    description String?
    ownerId     Int
    owner       User     @relation(fields: [ownerId], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    fileType    FileType @default(USER_UPLOADED_FILE)

    @@index([ownerId])
}
